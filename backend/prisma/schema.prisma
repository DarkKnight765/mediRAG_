generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String?
  googleId      String?        @unique
  avatar        String?
  name          String?
  conversations Conversation[]
  appointments  Appointment[]
  healthPlans   HealthPlan[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Conversation {
  id        Int       @id @default(autoincrement())
  title     String?
  user      User?     @relation(fields: [userId], references: [id])
  userId    Int?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
  role           String
  content        String
  modelOutput    ModelOutput?
  createdAt      DateTime     @default(now())
}

model ModelOutput {
  id        Int      @id @default(autoincrement())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId Int      @unique
  engine    String
  raw       String
  createdAt DateTime @default(now())
}

model Appointment {
  id               Int      @id @default(autoincrement())
  userId           Int
  patientName      String
  email            String
  phone            String
  doctor           String
  specialty        String
  appointmentType  String
  date             DateTime
  time             String
  reasonForVisit   String
  symptoms         String?
  medicalHistory   String?
  status           String   @default("SCHEDULED") // SCHEDULED | CONFIRMED | PENDING | CANCELLED | IN_PROGRESS | COMPLETED
  location         String?  // clinic/hospital name
  address          String?  // full address
  latitude         Float?
  longitude        Float?
  consultationFee  String?
  consultationMode String   @default("IN_PERSON") // IN_PERSON | VIDEO
  reminderSent24h  Boolean  @default(false)
  reminderSent1h   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model HealthPlan {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  input     String
  result    String
  engine    String
  createdAt DateTime @default(now())
}
