# Example .env for backend
DATABASE_URL=postgres://medirag:medirag@localhost:5432/medirag
GEMINI_API_KEY=
GEMINI_API_KEY_FILE=
LOCAL_MODEL_URL=http://localhost:8000
# If you want to use the local mock model server for development, set LOCAL_MODEL_URL to the mock server address.
# Example: LOCAL_MODEL_URL=http://localhost:8000
# You can start the mock model server with: `npm run mock-model` (from the `backend` directory).
# The mock server forwards to Ollama if `OLLAMA_BASE_URL` and `OLLAMA_MODEL` are set, otherwise it returns deterministic mock replies.
MOCK_MODEL_PORT=8000
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
MODEL_NAME=gemini-2.0-flash
PORT=3001

# Groq API configuration (get a key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# JWT secret for user authentication (change this in production!)
JWT_SECRET=medirag-dev-secret-change-in-production

# Leave OLLAMA_BASE_URL and OLLAMA_MODEL empty until you install Ollama locally.